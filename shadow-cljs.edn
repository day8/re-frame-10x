;; Root-level shadow-cljs config for re-frame-10x. The library build
;; is still driven by lein/project.clj — this file exists ONLY to give
;; the .cljs test suite a runnable target so CI can gate on it.
;;
;; See DEVELOPERS.md "Running tests" for the dual-path (lein test for
;; the JVM-side suite; npx shadow-cljs compile test for the cljs side).
;;
;; The :dependencies declared here are the *real* (userland) re-frame
;; and reagent that live next to the inlined-deps copies in gen-src.
;; They are NOT 10x's own pipeline — 10x runs against the inlined
;; v1v3v0 copy under day8.re-frame-10x.inlined-deps. They are the
;; deliberate integration boundary: a handful of 10x source files reach
;; into userland to register handlers users can dispatch, intercept the
;; userland trace stream, and reset the userland app-db for time-travel.
;; In production these resolve via the host application's classpath; in
;; this test build they resolve via the deps below.
;;
;; Every such crossing in 10x's source is aliased under the
;; `userland.re-frame[.X]` prefix at its `:require` site (see e.g.
;; navigation/epochs/events.cljs, navigation/views.cljs, fx/trace.cljs,
;; panels/app-db/events.cljs, panels/app-db/views.cljs) so the boundary
;; is visible from the call site without cross-referencing require
;; lists. Files under src/day8/reagent/impl/ are 10x's reagent monkey-
;; patches and reach into userland reagent by definition; the require
;; aliases there (`:as batching`, `:as trace`) are file-local and don't
;; follow the `userland.*` convention because every require in those
;; files is userland by construction. New crossings — userland-aimed
;; requires in src/day8/re_frame_10x/* — should adopt the
;; `userland.re-frame[.X]` aliasing for grep-ability.

{:source-paths ["src" "gen-src" "test"]

 :dependencies [[reagent "1.2.0"]
                [re-frame "1.4.5"]]

 :builds
 {:test
  {:target    :node-test
   :output-to "out/node-tests.js"
   :ns-regexp "-test$"
   :autorun   true}

  ;; :advanced-mode build of the public surface plus a tiny probe that
  ;; asserts every ^:export var in public.cljs resolves on goog.global
  ;; after Closure mangling. Source-side ^:export presence is gated by
  ;; the JVM test public_export_metadata_test.clj; this build gates
  ;; the emit side, which :node-test (always :none) can never exercise.
  ;; Run via `npx shadow-cljs compile public-advanced` then
  ;; `node out/public-advanced.js`. CI wires both in series.
  :public-advanced
  {:target           :node-script
   :main             day8.re-frame-10x.public-advanced-probe/-main
   :output-to        "out/public-advanced.js"
   :compiler-options {:optimizations :advanced}}}}
